// Secrets.xcconfig — Copy this file to Secrets.xcconfig and fill in your credentials.
//
// NOTE: The /$()/ syntax is required because xcconfig treats // as a comment.
// The $() expands to an empty string, producing the correct URL at build time.

SUPABASE_URL = https:/$()/YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY = YOUR_SUPABASE_PUBLISHABLE_KEY
